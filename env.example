# Port to listen on (default: 3001)
PORT=3001

# Your MassTimes API key (the public demo key is pre-filled in server.js)
# Request a production key at: https://masstimes.org/
MASSTIMES_API_KEY=74e45c40-7f11-11e1-b0c4-0800200c9a66

# Restrict CORS to your frontend domain in production
# ALLOWED_ORIGIN=https://yoursanctusapp.com
ALLOWED_ORIGIN=*
